# --- Secrets: never commit these ---
*.pem
*.key
.env
.env.*

# --- Terraform state (contains resource IDs, IPs, sometimes secrets) ---
*.tfstate
*.tfstate.*
terraform_tfstate.backup
.terraform/
.terraform.lock.hcl
crash.log
crash.*.log

# --- Per-deployment generated config (regenerated each run) ---
terraform/terraform.tfvars
ansible/inventory.ini

# --- Python ---
__pycache__/
*.pyc
myenv/
venv/
.venv/

# --- OS / editor cruft ---
.DS_Store
.vscode/
